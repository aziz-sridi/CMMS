@page "/locations"
@attribute [Authorize]
@inject ILocationService LocationService

<PageTitle>Locations — CMMS</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-building me-2"></i>Locations</h2>
    <AuthorizeView Roles="Manager">
        <a href="/locations/create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Add Location</a>
    </AuthorizeView>
</div>

<form method="get" class="mb-3">
    <div class="input-group" style="max-width:360px">
        <input type="text" name="search" value="@Search" class="form-control" placeholder="Search by name…" />
        <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
        @if (!string.IsNullOrEmpty(Search)) { <a href="/locations" class="btn btn-outline-danger"><i class="bi bi-x-lg"></i></a> }
    </div>
</form>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Name</th><th>Type</th><th>Parent</th>
                    <AuthorizeView Roles="Manager"><th></th></AuthorizeView>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in locations)
                {
                    <tr>
                        <td class="fw-semibold">@item.Name</td>
                        <td><span class="badge bg-info text-dark">@item.Type</span></td>
                        <td class="text-muted">@(item.ParentLocation?.Name ?? "—")</td>
                        <AuthorizeView Roles="Manager">
                            <td>
                                <a href="/locations/edit/@item.Id" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                                <a href="/locations/delete/@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </AuthorizeView>
                    </tr>
                }
                @if (!locations.Any()) { <tr><td colspan="4" class="text-center text-muted py-4">No locations found.</td></tr> }
            </tbody>
        </table>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Search { get; set; }
    private List<Location> locations = new();

    protected override async Task OnInitializedAsync()
    {
        var all = await LocationService.GetAllAsync(Search);
        locations = all.OrderBy(l => l.Type).ThenBy(l => l.Name).ToList();
    }
}
