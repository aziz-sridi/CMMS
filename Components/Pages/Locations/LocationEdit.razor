@page "/locations/edit/{Id:guid}"
@attribute [Authorize(Roles = "Manager")]
@inject ILocationService LocationService
@inject NavigationManager Nav

<PageTitle>Edit Location — CMMS</PageTitle>

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/locations" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h2 class="mb-0">Edit Location</h2>
</div>

<div class="card shadow-sm" style="max-width:500px">
    <div class="card-body">
        <EditForm Model="Input" method="post" OnValidSubmit="HandleSubmitAsync" FormName="edit-location">
            <DataAnnotationsValidator />
            <ValidationSummary class="alert alert-danger" />
            <div class="mb-3">
                <label class="form-label">Name</label>
                <InputText @bind-Value="Input!.Name" class="form-control" />
                <ValidationMessage For="() => Input!.Name" class="text-danger small" />
            </div>
            <div class="mb-3">
                <label class="form-label">Type</label>
                <InputSelect @bind-Value="Input!.Type" class="form-select">
                    @foreach (var t in Enum.GetValues<LocationType>()) { <option value="@t">@t</option> }
                </InputSelect>
            </div>
            <div class="mb-3">
                <label class="form-label">Parent Location (optional)</label>
                <InputSelect @bind-Value="Input!.ParentLocationId" class="form-select">
                    <option value="@((Guid?)null)">— None —</option>
                    @foreach (var l in parentOptions) { <option value="@l.Id">@l.Name</option> }
                </InputSelect>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a href="/locations" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public Guid Id { get; set; }
    [SupplyParameterFromForm(FormName = "edit-location")] public InputModel? Input { get; set; }
    private List<Location> parentOptions = new();

    protected override async Task OnInitializedAsync()
    {
        var all = await LocationService.GetAllAsync();
        parentOptions = all.Where(l => l.Id != Id).ToList();

        if (Input is null)
        {
            var e = await LocationService.GetByIdAsync(Id);
            if (e is null) { Nav.NavigateTo("/locations"); return; }
            Input = new InputModel { Name = e.Name, Type = e.Type, ParentLocationId = e.ParentLocationId };
        }
    }

    private async Task HandleSubmitAsync()
    {
        var ok = await LocationService.UpdateAsync(new Location
        {
            Id = Id,
            Name = Input!.Name.Trim(),
            Type = Input.Type,
            ParentLocationId = Input.ParentLocationId
        });
        if (!ok) { Nav.NavigateTo("/locations"); return; }
        Nav.NavigateTo("/locations");
    }

    public sealed class InputModel
    {
        [Required, StringLength(150, MinimumLength = 2)] public string Name { get; set; } = string.Empty;
        public LocationType Type { get; set; }
        public Guid? ParentLocationId { get; set; }
    }
}
