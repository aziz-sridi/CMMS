@page "/users"
@attribute [Authorize(Roles = "Manager")]
@inject AppDbContext db
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav

<PageTitle>User Management — CMMS</PageTitle>

<h2 class="mb-2"><i class="bi bi-people me-2"></i>User Management</h2>
<p class="text-muted small mb-4">Assign roles to registered accounts. New registrations have no role by default.</p>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr><th>Email</th><th>Full Name</th><th>Current Role</th><th>Assign Role</th></tr>
            </thead>
            <tbody>
                @foreach (var row in users)
                {
                    <tr>
                        <td>@row.User.Email</td>
                        <td class="text-muted">@(row.User.FullName.Length > 0 ? row.User.FullName : "—")</td>
                        <td>
                            @if (row.Roles.Any())
                            {
                                foreach (var r in row.Roles)
                                {
                                    <span class="badge @(r == "Manager" ? "bg-primary" : "bg-secondary") me-1">@r</span>
                                }
                            }
                            else { <span class="text-muted small">No role</span> }
                        </td>
                        <td>
                            <form method="post" action="/Identity/Account/SetRole" class="d-flex gap-2">
                                <AntiforgeryToken />
                                <input type="hidden" name="userId" value="@row.User.Id" />
                                <select name="role" class="form-select form-select-sm" style="width:140px">
                                    <option value="" selected="@(!row.Roles.Any())">— No role —</option>
                                    <option value="Manager" selected="@(row.Roles.Contains("Manager"))">Manager</option>
                                    <option value="Technician" selected="@(row.Roles.Contains("Technician"))">Technician</option>
                                </select>
                                <button type="submit" class="btn btn-sm btn-outline-primary">Apply</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<(ApplicationUser User, IList<string> Roles)> users = new();

    protected override async Task OnInitializedAsync()
    {
        var allUsers = await db.Users.OfType<ApplicationUser>().OrderBy(u => u.Email).ToListAsync();
        foreach (var user in allUsers)
        {
            var roles = await UserManager.GetRolesAsync(user);
            users.Add((user, roles));
        }
    }
}
